<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="access_role_view_form" model="ir.ui.view">
        <field name="name">access.role.view.form</field>
        <field name="model">access.role</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div name="button_box" position="inside">
                        <button class="oe_stat_button" type="object" icon="fa-users"
                                name="action_get_groups">
                            <field string="Groups" name="groups_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-list"
                                name="action_get_accesses">
                            <field string="Access Rights" name="accesses_count"
                                   widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-list-ul"
                                name="action_get_rules">
                            <field string="Record Rules" name="rules_count"
                                   widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <div class="oe_title">
                                <label for="name" string="Role"/>
                                <h1>
                                    <div class="d-flex">
                                        <field class="text-break" name="name"
                                               options="{'line_breaks': False}"
                                               placeholder="e.g. Staff"
                                               widget="text"/>
                                    </div>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags"  options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook colspan="4">
                        <page name="supply_chain" string="Supply Chain 快捷权限">
                            <div class="text-muted mb-3">
                                在此选择供应链（Supply Chain）下各模块的访问权限，保存后将自动勾选 Access Rights 中对应的 User/Administrator 组。
                            </div>
                            <group>
                                <group string="Manufacturing（制造）">
                                    <field name="manufacturing_access"
                                           placeholder="未设置"/>
                                </group>
                                <group string="PLM（产品生命周期）">
                                    <field name="plm_access" placeholder="未设置"/>
                                </group>
                                <group string="Quality（质量）">
                                    <field name="quality_access" placeholder="未设置"/>
                                </group>
                                <group string="Purchase（采购）">
                                    <field name="purchase_access" placeholder="未设置"/>
                                </group>
                                <group string="Inventory（库存）">
                                    <field name="inventory_access" placeholder="未设置"/>
                                </group>
                                <group string="Maintenance（维护保养）">
                                    <field name="maintenance_access"/>
                                </group>
                            </group>
                        </page>
                        <page name="access_rights" string="Access Rights">
                            <field name="groups_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="access_role_view_form_groups" model="ir.ui.view">
        <field name="name">access.role.view.form.groups</field>
        <field name="model">access.role</field>
        <field name="inherit_id" ref="access_role_view_form"/>
        <field name="arch" type="xml">
            <!-- dummy, will be modified by groups -->
            <field name="groups_ids" position="after"/>
        </field>
    </record>
    <record id="access_role_view_list" model="ir.ui.view">
        <field name="name">access.role.view.list</field>
        <field name="model">access.role</field>
        <field name="arch" type="xml">
            <list string="Roles">
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"
                       options="{'no_create': True, 'no_open': True}"/>
                <field name="groups_count"/>
                <field name="accesses_count"/>
                <field name="rules_count"/>
                <field name="role_management_id" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="action_access_role" model="ir.actions.act_window">
        <field name="name">Access Roles</field>
        <field name="res_model">access.role</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>