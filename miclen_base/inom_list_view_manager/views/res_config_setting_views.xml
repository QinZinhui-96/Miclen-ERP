<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inom_lvm" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inom.lvm</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="40"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block"
                     string="List View Manager"
                     data-string="List View Manager"
                     data-key="inom_list_view_manager"
                     groups="base.group_system">

                    <h2>List View Manager</h2>

                    <div class="row mt16 o_settings_container lvm_color_container">

                        <!-- Toggle Color -->
                        <div class="col-12 col-lg-4 o_setting_box">

                            <div class="o_setting_right_pane">

                                <div class="o_form_label">
                                    Toggle Color
                                </div>

                                <div class="mt8">
                                    <field name="toggle_color"
                                           widget="color"/>
                                </div>

                            </div>

                        </div>

                        <!-- Header Color -->
                        <div class="col-12 col-lg-4 o_setting_box">

                            <div class="o_setting_right_pane">

                                <div class="o_form_label">
                                    LVM Header Color
                                </div>

                                <div class="mt8">
                                    <field name="header_color"
                                           widget="color"/>
                                </div>

                            </div>

                        </div>

                        <!-- Header Text Color -->
                        <div class="col-12 col-lg-4 o_setting_box">

                            <div class="o_setting_right_pane">

                                <div class="o_form_label">
                                    Header Text Color
                                </div>

                                <div class="mt8">
                                    <field name="header_text_color"
                                           widget="color"/>
                                </div>

                            </div>

                        </div>

                        <div class="col-12 col-lg-4 o_setting_box">

                            <div class="o_setting_right_pane">

                                <div class="o_form_label">
                                    Enable Serial Number
                                </div>
                                <div class="text-muted">
                                    Show serial number column in all list views
                                </div>
                                <div class="mt8">
                                    <field name="enable_serial_number"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>