<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inom_list_view_manager.BackToTopButton">
        <button t-if="state.visible"
                type="button"
                class="inom_back_to_top"
                t-att-title="label"
                t-att-aria-label="label"
                t-on-click="onClick">
            <i class="fa fa-chevron-up" role="img" aria-hidden="true"/>
        </button>
    </t>

</templates>
