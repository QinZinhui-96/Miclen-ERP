<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ 产品表单：在 purchase_ok 后面增加卷料标记 ============ -->
    <record id="product_template_form_view_inherit_roll_material" model="ir.ui.view">
        <field name="name">product.template.form.inherit.roll.material</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- 在 purchase_ok 的 span 后面插入卷料标记 -->
            <xpath expr="//div[@name='options']//span[field[@name='purchase_ok']]" position="after">
                <span class="d-inline-flex">
                    <field name="is_roll_material"/>
                    <label for="is_roll_material"/>
                </span>
            </xpath>
            <!-- 在通用信息组中增加规格长和规格宽 -->
            <xpath expr="//field[@name='product_tooltip']" position="after">
                <field name="spec_length" invisible="not is_roll_material" string="规格长(mm)"/>
                <field name="spec_width" invisible="not is_roll_material" string="规格宽(mm)"/>
            </xpath>
        </field>
    </record>

</odoo>
