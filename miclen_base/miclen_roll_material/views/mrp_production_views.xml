<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ 制造单表单：增加卷料选料按钮 ============ -->
    <record id="mrp_production_form_view_inherit_roll_material" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.roll.material</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <!-- 在 button_box 中增加选料按钮 -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" name="action_open_roll_material_wizard"
                        type="object" icon="fa-stack-overflow"
                        invisible="not has_roll_material_config"
                        string="卷料选料">
                </button>
            </xpath>
            <!-- 隐藏字段 -->
            <xpath expr="//sheet" position="inside">
                <field name="has_roll_material_config" invisible="1"/>
                <field name="roll_material_config_id" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
