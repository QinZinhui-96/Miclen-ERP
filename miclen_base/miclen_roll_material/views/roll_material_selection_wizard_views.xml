<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ 选料预览向导 - 表单视图 ============ -->
    <record id="roll_material_selection_wizard_form_view" model="ir.ui.view">
        <field name="name">roll.material.selection.wizard.form</field>
        <field name="model">roll.material.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="卷料选料预览">
                <header>
                    <button name="action_apply" type="object" string="应用到制造单" class="btn-primary"
                            invisible="not production_id or has_shortage"/>
                    <button name="action_apply" type="object" string="强制应用（含缺口）" class="btn-warning"
                            confirm="存在库存缺口，部分卷料无法满足需求。确定要应用吗？"
                            invisible="not production_id or not has_shortage"/>
                    <button name="action_preview" type="object" string="重新计算"/>
                </header>
                <sheet>
                    <group>
                        <group string="制造单信息">
                            <field name="production_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="product_qty" readonly="not production_id"/>
                        </group>
                        <group string="选料参数">
                            <field name="config_id" readonly="1"/>
                            <field name="required_length" readonly="1"/>
                            <field name="required_width" readonly="1"/>
                            <field name="gap" readonly="1"/>
                            <field name="has_shortage" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="选料结果">
                            <field name="line_ids">
                                <list>
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="roll_product_name"/>
                                    <field name="roll_width"/>
                                    <field name="pieces_per_row"/>
                                    <field name="cut_direction"/>
                                    <field name="consume_per_piece_mm"/>
                                    <field name="allocate_pieces"/>
                                    <field name="consume_qty"/>
                                    <field name="available_qty"/>
                                    <field name="shortage_pieces"/>
                                    <field name="shortage_qty"/>
                                    <field name="roll_product_id" column_invisible="1"/>
                                </list>
                            </field>
                            <div class="alert alert-warning" invisible="not has_shortage"
                                 role="alert">
                                <strong>注意：</strong>部分卷料库存不足，存在缺口。应用后将在制造单中创建已满足的部分，
                                缺口部分需手动采购补货。
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
