<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ 卷料选料配置 - 列表视图 ============ -->
    <record id="roll_material_config_tree_view" model="ir.ui.view">
        <field name="name">roll.material.config.tree</field>
        <field name="model">roll.material.config</field>
        <field name="arch" type="xml">
            <list string="卷料选料配置">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="required_length"/>
                <field name="required_width"/>
                <field name="gap"/>
                <field name="line_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ============ 卷料选料配置 - 表单视图 ============ -->
    <record id="roll_material_config_form_view" model="ir.ui.view">
        <field name="name">roll.material.config.form</field>
        <field name="model">roll.material.config</field>
        <field name="arch" type="xml">
            <form string="卷料选料配置">
                <header>
                    <button name="action_test_selection" type="object" string="测试选料" class="btn-primary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="归档" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="如：金属外壳-选料配置"/></h1>
                    </div>
                    <group>
                        <group string="关联产品">
                            <field name="product_id"/>
                            <field name="product_tmpl_id" invisible="1"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group string="需求参数">
                            <field name="required_length"/>
                            <field name="required_width"/>
                            <field name="gap"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="卷料优先级" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="roll_product_id" domain="[('is_roll_material', '=', True)]"/>
                                    <field name="roll_width"/>
                                    <field name="roll_length"/>
                                    <field name="available_qty"/>
                                    <field name="min_stock"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============ 卷料选料配置 - 搜索视图 ============ -->
    <record id="roll_material_config_search_view" model="ir.ui.view">
        <field name="name">roll.material.config.search</field>
        <field name="model">roll.material.config</field>
        <field name="arch" type="xml">
            <search string="卷料选料配置">
                <field name="name"/>
                <field name="product_id"/>
                <separator/>
                <filter name="filter_active" string="启用" domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="归档" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ============ 动作 ============ -->
    <record id="action_roll_material_config" model="ir.actions.act_window">
        <field name="name">卷料选料配置</field>
        <field name="res_model">roll.material.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="roll_material_config_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                创建第一条卷料选料配置
            </p>
            <p>
                配置成品的卷料选料规则，包括需求尺寸、切割间距和可用卷料优先级。
                系统将自动计算最优卷料选择方案。
            </p>
        </field>
    </record>

    <!-- ============ 菜单 ============ -->
    <menuitem id="menu_roll_material_root"
              name="卷料管理"
              sequence="90"/>

    <menuitem id="menu_roll_material_config"
              name="选料配置"
              parent="menu_roll_material_root"
              action="action_roll_material_config"
              sequence="10"/>

</odoo>
