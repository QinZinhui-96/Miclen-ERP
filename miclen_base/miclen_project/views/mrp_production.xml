<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mrp_production_form_inherit_miclen" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.miclen</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='components']//field[@name='move_raw_ids']//list//field[@name='product_uom']" position="after">
                <field name="coil_id" optional="show" options="{'no_create': True, 'no_open': True}"/>
                <field name="coil_x" optional="show" invisible="not coil_id"/>
                <field name="coil_y" optional="show" invisible="not coil_id"/>
                <field name="is_coil_expanded" optional="hide" column_invisible="1"/>
                <button name="action_button_consume"
                        type="object" string="卷料消耗" class="btn-primary" context="{'default_product_id': product_id}"
                        invisible="not coil_id or state in ['done', 'cancel']"/>
            </xpath>
        </field>
    </record>

</odoo>
