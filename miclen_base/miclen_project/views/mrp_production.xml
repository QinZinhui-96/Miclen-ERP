<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mrp_production_form_inherit_miclen" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.miclen</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='components']//field[@name='move_raw_ids']//list//field[@name='product_uom']" position="after">
                <field name="miclen_is_coil" optional="hide"  column_invisible="1"/>
                <field name="miclen_coil_w" optional="hide" invisible="not miclen_is_coil"/>
                <field name="miclen_coil_l" optional="hide" invisible="not miclen_is_coil"/>
                <field name="miclen_gap" optional="hide" invisible="not miclen_is_coil"/>
                <field name="miclen_condition" optional="hide" invisible="not miclen_is_coil"/>
                <button name="action_button_consume"
                        type="object" string="卷料消耗" class="btn-primary" context="{'default_product_id': product_id}"
                        invisible="not miclen_is_coil or state in ['done', 'cancel']"/>
            </xpath>
        </field>
    </record>

</odoo>
