<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- 在作业类型表单中添加负责人字段 -->
    <record id="view_mrp_workcenter_view_inherit" model="ir.ui.view">
        <field name="name">mrp.workcenter.form</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <group name="costing" position="inside">
                <field name="manager_users" widget="many2many_tags"
                       options="{'no_create': True, 'no_open': True}"/>
            </group>
        </field>
    </record>

    <record id="view_mrp_workcenter_tree_view_inherit" model="ir.ui.view">
        <field name="name">mrp.workcenter.list</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="manager_users" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
    
</odoo>