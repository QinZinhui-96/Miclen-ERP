<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="miclen_category_details_list_view">
        <field name="name">miclen.category.details.list</field>
        <field name="model">miclen.category.details</field>
        <field name="arch" type="xml">
            <list string="Miclen产品类别配置" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name" required="1"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="miclen_category_details_form_view">
        <field name="name">miclen.category.details.form</field>
        <field name="model">miclen.category.details</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
