<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 规则1：系统管理员可以看到所有作业类型 -->
        <record id="miclen_stock_picking_type_rule_admin" model="ir.rule">
            <field name="name">库存概览 - 管理员全部可见</field>
            <field name="model_id" ref="stock.model_stock_picking_type"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <!-- 只对系统管理员组生效 -->
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 规则2：普通用户只能看到自己被分配的作业类型 -->
        <record id="miclen_stock_picking_type_rule_user" model="ir.rule">
            <field name="name">库存概览 - 按负责人限制</field>
            <field name="model_id" ref="stock.model_stock_picking_type"/>
            <field name="domain_force">[('manager_users', 'in', user.ids)]</field>
            <!-- 只对普通用户（非管理员）生效 -->
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>



        <!-- 规则1：系统管理员可以看到所有质量团队 -->
        <record id="miclen_quality_alert_team_rule_admin" model="ir.rule">
            <field name="name">质量概览 - 管理员全部可见</field>
            <field name="model_id" ref="quality.model_quality_alert_team"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <!-- 只对系统管理员组生效 -->
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 规则2：普通用户只能看到自己被分配的质量团队 -->
        <record id="miclen_quality_alert_team_rule_user" model="ir.rule">
            <field name="name">质量概览 - 按负责人限制</field>
            <field name="model_id" ref="quality.model_quality_alert_team"/>
            <field name="domain_force">[('manager_users', 'in', user.ids)]</field>
            <!-- 只对普通用户（非管理员）生效 -->
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>



        <!-- 规则1：系统管理员可以看到所有生产概览 -->
        <record id="miclen_mrp_workcenter_rule_admin" model="ir.rule">
            <field name="name">生产概览 - 管理员全部可见</field>
            <field name="model_id" ref="mrp.model_mrp_workcenter"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <!-- 只对系统管理员组生效 -->
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 规则2：普通用户只能看到自己被分配的生产概览 -->
        <record id="miclen_mrp_workcenter_rule_user" model="ir.rule">
            <field name="name">生产概览 - 按负责人限制</field>
            <field name="model_id" ref="mrp.model_mrp_workcenter"/>
            <field name="domain_force">[('manager_users', 'in', user.ids)]</field>
            <!-- 只对普通用户（非管理员）生效 -->
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
