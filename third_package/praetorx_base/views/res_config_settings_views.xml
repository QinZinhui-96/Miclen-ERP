<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Settings Form with Praetorx Settings -->
    <record id="res_config_settings_view_form_praetorx" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.praetorx</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Praetorx" string="Praetorx" name="praetorx_base">
                    <block title="Module-Verwaltung" name="praetorx_appstore_settings">
                        <setting string="PraetorX Module" help="Alle PraetorX Module im Überblick">
                            <button name="%(action_praetorx_appstore)d"
                                    type="action"
                                    string="Module-Verwaltung öffnen"
                                    class="btn-primary"
                                    icon="fa-th"/>
                        </setting>
                    </block>
                    <block title="PDF Reports" name="praetorx_report_settings">
                        <setting string="PDF Display Mode" help="Controls how PDF reports are shown when printed">
                            <field name="praetorx_report_display_mode" widget="radio"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
