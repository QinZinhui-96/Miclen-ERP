<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Queue Job Form View -->
    <record id="view_queue_job_form" model="ir.ui.view">
        <field name="name">praetorx.queue.job.form</field>
        <field name="model">praetorx.queue.job</field>
        <field name="arch" type="xml">
            <form string="Queue Job">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="pending,processing,done"/>
                    <button name="action_retry"
                            string="Retry"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'failed'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('pending', 'processing')"
                            confirm="Are you sure you want to cancel this job?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_name"/>
                            <field name="method_name"/>
                        </group>
                        <group>
                            <field name="create_uid" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="record_ids" widget="ace" options="{'mode': 'json'}"/>
                    </group>
                    <group invisible="state != 'failed'">
                        <field name="error_message" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Queue Job List View -->
    <record id="view_queue_job_tree" model="ir.ui.view">
        <field name="name">praetorx.queue.job.list</field>
        <field name="model">praetorx.queue.job</field>
        <field name="arch" type="xml">
            <list string="Queue Jobs"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'failed'"
                  decoration-info="state == 'processing'"
                  decoration-muted="state == 'pending'">
                <field name="create_date"/>
                <field name="name"/>
                <field name="model_name"/>
                <field name="method_name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'failed'"
                       decoration-info="state == 'processing'"
                       decoration-warning="state == 'pending'"/>
                <field name="started_at"/>
                <field name="finished_at"/>
                <field name="create_uid"/>
            </list>
        </field>
    </record>

    <!-- Queue Job Search View -->
    <record id="view_queue_job_search" model="ir.ui.view">
        <field name="name">praetorx.queue.job.search</field>
        <field name="model">praetorx.queue.job</field>
        <field name="arch" type="xml">
            <search string="Queue Jobs">
                <field name="name" filter_domain="[('name', 'ilike', self)]"/>
                <field name="model_name"/>
                <field name="method_name"/>
                <field name="create_uid"/>
                <separator/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Processing" name="filter_processing" domain="[('state', '=', 'processing')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Failed" name="filter_failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter string="My Jobs" name="filter_my_jobs" domain="[('create_uid', '=', uid)]"/>
                <separator/>
                <filter string="Today" name="filter_today"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="filter_week"
                        domain="[('create_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Model" name="group_model" context="{'group_by': 'model_name'}"/>
                <filter string="Method" name="group_method" context="{'group_by': 'method_name'}"/>
                <filter string="Created By" name="group_user" context="{'group_by': 'create_uid'}"/>
                <filter string="Creation Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
            </search>
        </field>
    </record>

    <!-- Queue Job Action -->
    <record id="action_queue_job" model="ir.actions.act_window">
        <field name="name">Queue Jobs</field>
        <field name="res_model">praetorx.queue.job</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No queue jobs yet
            </p>
            <p>
                Queue jobs allow you to process records in the background
                without blocking the user interface. Jobs are processed
                automatically by a cron task.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_praetorx_base_root"
              name="Praetorx"
              sequence="100"
              web_icon="praetorx_base,static/description/icon.png"/>

    <menuitem id="menu_praetorx_base_technical"
              name="Technical"
              parent="menu_praetorx_base_root"
              sequence="90"/>

    <menuitem id="menu_queue_job"
              name="Queue Jobs"
              parent="menu_praetorx_base_technical"
              action="action_queue_job"
              sequence="10"/>

</odoo>
