<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron Job: Process Queue Jobs -->
        <record id="ir_cron_process_queue_jobs" model="ir.cron">
            <field name="name">Praetorx: Process Queue Jobs</field>
            <field name="model_id" ref="model_praetorx_queue_job"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_jobs(batch_size=100)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
