#: model:mail.template,body_html:dynamic_approval_workflow.email_template_approval_request
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">
    <p style=\"margin: 0px;"
"padding: 0px; font-size: 13px;\">
        Dear {{"
"ctx.get('approver_name', 'Approver') }},
    </p>
    <br/>
    <p"
"style=\"margin: 0px; padding: 0px; font-size: 13px;\">
        An"
"approval request requires your action:
    </p>
    <br/>
    <table"
"style=\"border: 1px solid #dee2e6; border-collapse: collapse; width:"
"100%; font-size: 13px;\">
        <tr>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold; width: 35%;\">Reference</td>
           "
"<td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.name }}</td>
        </tr>
        <tr>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">Document</td>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.res_name }}</td>
        </tr>
        <tr>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">Workflow</td>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.config_id.name }}</td>
        </tr>
        <tr>
           "
"<td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">Stage</td>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.current_stage_id.name }}</td>
        </tr>
        <tr>
      "
"<td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">Requested By</td>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.requester_id.name }}</td>
        </tr>
        {% if"
"object.deadline %}
        <tr>
            <td style=\"padding: 8px"
"12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight:"
"bold;\">Deadline</td>
            <td style=\"padding: 8px 12px;"
"border: 1px solid #dee2e6; color: #dc3545;\">{{ object.deadline"
"}}</td>
        </tr>
        {% endif %}
    </table>
    <br/>
   "
"<p style=\"margin: 0px; padding: 0px; font-size: 13px;\">
       "
"Please log in to Odoo and review the request at your earliest"
"convenience.
    </p>
    <br/>
    <p style=\"margin: 0px; padding:"
"0px; font-size: 13px;\">
        <a"
"href=\"/web#model=approval.request&amp;id={{ object.id"
"}}&amp;view_type=form\" style=\"background-color: #875A7B; color:"
"#fff; padding: 8px 16px;&#10;                  text-decoration: none;"
"border-radius: 4px; font-size: 13px;\">
            Review Request
   "
"</a>
    </p>
    <br/>
    <p style=\"margin: 0px; padding: 0px;"
"font-size: 12px; color: #6c757d;\">
        This is an automated"
"notification from your Odoo system.
    </p>
</div>
        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">
    <p style=\"margin: 0px;"
"padding: 0px; font-size: 13px;\">
        尊敬的 {{"
"ctx.get('approver_name', 'Approver') }}：
    </p>
    <br/>
    <p"
"style=\"margin: 0px; padding: 0px; font-size: 13px;\">
       "
"有一项审批请求需要您处理：
    </p>
    <br/>
    <table style=\"border: 1px solid"
"#dee2e6; border-collapse: collapse; width: 100%; font-size: 13px;\">
 "
"<tr>
            <td style=\"padding: 8px 12px; border: 1px solid"
"#dee2e6; background: #f8f9fa; font-weight: bold; width:"
"35%;\">参考编号</td>
            <td style=\"padding: 8px 12px; border:"
"1px solid #dee2e6;\">{{ object.name }}</td>
        </tr>
       "
"<tr>
            <td style=\"padding: 8px 12px; border: 1px solid"
"#dee2e6; background: #f8f9fa; font-weight: bold;\">单据</td>
           "
"<td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.res_name }}</td>
        </tr>
        <tr>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">工作流</td>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{"
"object.config_id.name }}</td>
        </tr>
        <tr>
           "
"<td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">阶段</td>
            <td style=\"padding:"
"8px 12px; border: 1px solid #dee2e6;\">{{ object.current_stage_id.name"
"}}</td>
        </tr>
        <tr>
            <td style=\"padding:"
"8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight:"
"bold;\">申请人</td>
            <td style=\"padding: 8px 12px; border:"
"1px solid #dee2e6;\">{{ object.requester_id.name }}</td>
       "
"</tr>
        {% if object.deadline %}
        <tr>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6; background:"
"#f8f9fa; font-weight: bold;\">截止日期</td>
            <td"
"style=\"padding: 8px 12px; border: 1px solid #dee2e6; color:"
"#dc3545;\">{{ object.deadline }}</td>
        </tr>
        {% endif"
"%}
    </table>
    <br/>
    <p style=\"margin: 0px; padding: 0px;"
"font-size: 13px;\">
        请登录 Odoo 并尽快审阅该请求。
    </p>
    <br/>
   "
"<p style=\"margin: 0px; padding: 0px; font-size: 13px;\">
        <a"
"href=\"/web#model=approval.request&amp;id={{ object.id"
"}}&amp;view_type=form\" style=\"background-color: #875A7B; color:"
"#fff; padding: 8px 16px;&#10;                  text-decoration: none;"
"border-radius: 4px; font-size: 13px;\">
            审阅请求
        </a>
"
"</p>
    <br/>
    <p style=\"margin: 0px; padding: 0px; font-size:"
"12px; color: #6c757d;\">
        这是来自您的 Odoo 系统的自动通知。
    </p>
</div>
"
